{
    "name": "tuhin-su/laravel-generic-swal",
    "description": "A reusable global SweetAlert2 integration for Laravel and Livewire 3 with clean, secure, one-line PHP wrappers.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "tuhin-su",
            "homepage": "https://github.com/tuhin-su"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "livewire/livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelSwal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelSwal\\LaravelSwalServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
